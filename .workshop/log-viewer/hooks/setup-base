#!/usr/bin/env bash
set -euo pipefail

export DEBIAN_FRONTEND=noninteractive

apt-get update
apt-get install -y --no-install-recommends \
    ca-certificates \
    composer \
    curl \
    git \
    nodejs \
    npm \
    php-bcmath \
    php-cli \
    php-curl \
    php-gd \
    php-imagick \
    php-intl \
    php-mbstring \
    php-soap \
    php-sqlite3 \
    php-xml \
    php-zip \
    unzip \
    zip

apt-get clean
rm -rf /var/lib/apt/lists/*
