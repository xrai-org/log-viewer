{
    "name": "opcodesio/log-viewer",
    "description": "Fast and easy-to-use log viewer for your Laravel application (XRAI fork)",
    "keywords": [
        "arukompas",
        "opcodesio",
        "laravel",
        "logs",
        "log viewer",
        "better-log-viewer"
    ],
    "homepage": "https://github.com/XRAI-ORG/log-viewer",
    "license": "MIT",
    "authors": [
        {
            "name": "Arunas Skirius",
            "email": "arukomp@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.5",
        "illuminate/contracts": "^12.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^4.4",
        "pestphp/pest-plugin-laravel": "^4.1"
    },
    "autoload": {
        "psr-4": {
            "Opcodes\\LogViewer\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Opcodes\\LogViewer\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest --order-by random",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Opcodes\\LogViewer\\LogViewerServiceProvider"
            ],
            "aliases": {
                "LogViewer": "Opcodes\\LogViewer\\Facades\\LogViewer"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
